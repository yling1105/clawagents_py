# PinchBench Runner Image
# Pre-installs OpenClaw and dependencies for running benchmarks in CI

FROM node:22-bookworm

LABEL org.opencontainers.image.source="https://github.com/pinchbench/skill"
LABEL org.opencontainers.image.description="PinchBench benchmark runner with OpenClaw"

# Install system dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    git \
    curl \
    jq \
    && rm -rf /var/lib/apt/lists/*

# Install uv (Python package manager used by PinchBench)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh
ENV PATH="/root/.local/bin:$PATH"

# Install OpenClaw globally
RUN npm install -g openclaw

# Create workspace directory
WORKDIR /workspace

# Pre-create OpenClaw config directory
RUN mkdir -p /root/.openclaw

# Default entrypoint - can be overridden
ENTRYPOINT ["/bin/bash", "-c"]
CMD ["openclaw --version && echo 'Ready for benchmarks'"]
